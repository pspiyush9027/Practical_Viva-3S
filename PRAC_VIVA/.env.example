PORT=8000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/databaseName
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
PASSWORD_RESET_TOKEN_EXPIRES_IN=10m

# Abstract validates the email before the OTP is sent.
ABSTRACT_API_KEY=your_abstract_api_key

# Gmail SMTP credentials used by Nodemailer to actually deliver the OTP email.
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
